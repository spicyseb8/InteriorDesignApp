@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Profile - 3D Interior Design Planner</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #FFFFFF;
        }
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            box-shadow: 0 -2px 20px rgba(0,0,0,0.05);
            padding-bottom: env(safe-area-inset-bottom);
            border-top: 1px solid #F0F0F0;
            z-index: 100;
        }
        .nav-item {
            transition: all 0.3s ease;
            color: #999999;
        }
        .nav-item.active {
            color: #FA8112;
        }
        .nav-item:hover {
            color: #FA8112;
        }
        .content-container {
            padding-bottom: 100px;
        }
        .setting-item {
            background: #F8F9FA;
            border: 1px solid #F0F0F0;
            transition: all 0.3s ease;
        }
        .setting-item:hover {
            border-color: #FA8112;
            background: #FFFFFF;
            transform: translateX(4px);
        }
        .signout-btn {
            background-color: #FEF2F2;
            border: 1px solid #FEE2E2;
            color: #DC2626;
            transition: all 0.3s ease;
        }
        .signout-btn:hover {
            background-color: #DC2626;
            border-color: #DC2626;
            color: white;
        }
        /* Modal styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .modal-content {
            background: white;
            border-radius: 20px;
            padding: 24px;
            max-width: 320px;
            width: 90%;
            text-align: center;
        }
        .modal-btn {
            padding: 12px 20px;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .modal-btn-cancel {
            background-color: #F8F9FA;
            color: #666666;
        }
        .modal-btn-cancel:hover {
            background-color: #E8E8E8;
        }
        .modal-btn-confirm {
            background-color: #DC2626;
            color: white;
        }
        .modal-btn-confirm:hover {
            background-color: #B91C1C;
        }
    </style>
</head>
<body>
    <!-- Modal for Sign Out Confirmation -->
    <div id="signoutModal" class="modal">
        <div class="modal-content">
            <div class="w-14 h-14 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-sign-out-alt text-red-500 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-[#222222] mb-2">Sign Out?</h3>
            <p class="text-[#666666] text-sm mb-6">Are you sure you want to sign out of your account?</p>
            <div class="flex space-x-3">
                <button onclick="closeModal()" class="modal-btn modal-btn-cancel flex-1">Cancel</button>
                <button onclick="confirmSignOut()" class="modal-btn modal-btn-confirm flex-1">Sign Out</button>
            </div>
        </div>
    </div>

    <!-- Header -->
    <div class="px-5 pt-8 pb-4">
        <h1 class="text-3xl font-bold text-[#222222]">Profile</h1>
        <p class="text-[#666666] text-sm mt-1">Manage your account settings</p>
    </div>
    
    <!-- Settings Content -->
    <div class="content-container px-5 py-2">
        <!-- Profile Section -->
        <div class="mb-8">
            <h2 class="text-xs font-semibold text-[#999999] uppercase tracking-wider mb-3">Account</h2>
            <a href="/Design/Profile" class="setting-item rounded-xl p-4 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#FA8112]/10 rounded-xl flex items-center justify-center">
                        <i class="fas fa-user-circle text-[#FA8112] text-xl"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-[#222222]">Profile Information</p>
                        <p class="text-xs text-[#999999] mt-0.5">Update your personal details</p>
                    </div>
                </div>
                <i class="fas fa-chevron-right text-[#CCCCCC] text-sm"></i>
            </a>
        </div>
        
        <!-- Projects Section -->
        <div class="mb-8">
            <h2 class="text-xs font-semibold text-[#999999] uppercase tracking-wider mb-3">Designs</h2>
            <a href="/Design/MyProjects" class="setting-item rounded-xl p-4 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#FA8112]/10 rounded-xl flex items-center justify-center">
                        <i class="fas fa-folder-open text-[#FA8112] text-xl"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-[#222222]">My Projects</p>
                        <p class="text-xs text-[#999999] mt-0.5">View and manage your designs</p>
                    </div>
                </div>
                <i class="fas fa-chevron-right text-[#CCCCCC] text-sm"></i>
            </a>
        </div>
        
        <!-- Legal Section -->
        <div class="mb-8">
            <h2 class="text-xs font-semibold text-[#999999] uppercase tracking-wider mb-3">Legal</h2>
            <a href="/Design/Privacy" class="setting-item rounded-xl p-4 flex items-center justify-between mb-2">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#FA8112]/10 rounded-xl flex items-center justify-center">
                        <i class="fas fa-shield-alt text-[#FA8112] text-xl"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-[#222222]">Privacy Policy</p>
                        <p class="text-xs text-[#999999] mt-0.5">How we handle your data</p>
                    </div>
                </div>
                <i class="fas fa-chevron-right text-[#CCCCCC] text-sm"></i>
            </a>
            
            <a href="/Design/Terms" class="setting-item rounded-xl p-4 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#FA8112]/10 rounded-xl flex items-center justify-center">
                        <i class="fas fa-file-alt text-[#FA8112] text-xl"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-[#222222]">Terms & Conditions</p>
                        <p class="text-xs text-[#999999] mt-0.5">Terms of service</p>
                    </div>
                </div>
                <i class="fas fa-chevron-right text-[#CCCCCC] text-sm"></i>
            </a>
        </div>
        
        <!-- Sign Out Button -->
        <div class="mt-8 pb-8">
            <button onclick="openModal()" class="signout-btn w-full rounded-xl p-4 font-medium transition-all flex items-center justify-center space-x-2">
                <i class="fas fa-sign-out-alt"></i>
                <span>Sign Out</span>
            </button>
        </div>
    </div>
    
    <!-- Bottom Navigation Bar -->
    <div class="bottom-nav">
        <div class="flex justify-around py-3">
            <a href="/Design/Home" class="nav-item flex flex-col items-center">
                <i class="fas fa-home text-xl"></i>
                <span class="text-xs mt-1 font-medium">Home</span>
            </a>
            <a href="/Design/Settings" class="nav-item active flex flex-col items-center">
                <i class="fas fa-user text-xl"></i>
                <span class="text-xs mt-1 font-medium">Profile</span>
            </a>
        </div>
    </div>
    
    <script>
        document.querySelectorAll('.nav-item').forEach(item => {
            if (item.href === window.location.href) {
                item.classList.add('active');
            }
        });
        
        function openModal() {
            document.getElementById('signoutModal').style.display = 'flex';
        }
        
        function closeModal() {
            document.getElementById('signoutModal').style.display = 'none';
        }
        
        function confirmSignOut() {
            window.location.href = '/Account/Logout';
        }
        
        window.onclick = function(event) {
            var modal = document.getElementById('signoutModal');
            if (event.target === modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>