@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Privacy Policy - 3D Interior Design Planner</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #FFFFFF;
        }
    </style>
</head>
<body>
    <div class="min-h-screen">
        <!-- Header -->
        <div class="px-5 pt-8 pb-4">
            <div class="flex items-center">
                <a href="/Design/Settings" class="mr-4 text-[#666666] hover:text-[#FA8112] transition-colors">
                    <i class="fas fa-arrow-left text-xl"></i>
                </a>
                <h1 class="text-2xl font-bold text-[#222222]">Privacy Policy</h1>
            </div>
        </div>
        
        <div class="px-5 pb-8 max-w-3xl mx-auto">
            <div class="bg-[#F8F9FA] rounded-2xl p-6 border border-[#F0F0F0]">
                <p class="text-[#666666] text-sm mb-6">Last updated: December 2025</p>
                
                <h2 class="text-lg font-semibold text-[#222222] mt-6 mb-3">1. Information We Collect</h2>
                <p class="text-[#666666] text-sm leading-relaxed mb-3">
                    We collect information you provide directly to us, such as when you create an account, update your profile, or use our design services. This includes:
                </p>
                <ul class="list-disc list-inside text-[#666666] text-sm space-y-1 mb-6 ml-2">
                    <li>Account information (name, email address, username)</li>
                    <li>Design preferences and project data</li>
                    <li>Usage data and interaction with our 3D design tools</li>
                </ul>
                
                <h2 class="text-lg font-semibold text-[#222222] mt-6 mb-3">2. How We Use Your Information</h2>
                <p class="text-[#666666] text-sm leading-relaxed mb-3">
                    We use the information we collect to:
                </p>
                <ul class="list-disc list-inside text-[#666666] text-sm space-y-1 mb-6 ml-2">
                    <li>Provide, maintain, and improve our services</li>
                    <li>Process and complete your design projects</li>
                    <li>Send you technical notices and support messages</li>
                    <li>Respond to your comments and questions</li>
                </ul>
                
                <h2 class="text-lg font-semibold text-[#222222] mt-6 mb-3">3. Data Security</h2>
                <p class="text-[#666666] text-sm leading-relaxed mb-6">
                    We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction. Your passwords are hashed and never stored in plain text.
                </p>
                
                <h2 class="text-lg font-semibold text-[#222222] mt-6 mb-3">4. Data Sharing</h2>
                <p class="text-[#666666] text-sm leading-relaxed mb-6">
                    We do not sell, trade, or rent your personal information to third parties. We may share your information only with your consent or as required by law.
                </p>
                
                <h2 class="text-lg font-semibold text-[#222222] mt-6 mb-3">5. Your Rights</h2>
                <p class="text-[#666666] text-sm leading-relaxed mb-6">
                    You have the right to access, update, or delete your account information. You can do this through your profile settings or by contacting us directly.
                </p>
                
                <h2 class="text-lg font-semibold text-[#222222] mt-6 mb-3">6. Contact Us</h2>
                <p class="text-[#666666] text-sm leading-relaxed">
                    If you have questions about this Privacy Policy, please contact us at: privacy@interiordesignplanner.com
                </p>
            </div>
        </div>
    </div>
</body>
</html>